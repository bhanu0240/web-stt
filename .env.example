# Required for HF ASR + embeddings (read by the Express server from this file — not Vite-only)
HF_TOKEN=hf_your_token_here

# Optional overrides
# HF_ASR_TRANSCODE=true
# (default true: ffmpeg → 16 kHz mono WAV before ASR; supports mp4/m4a/webm/… Set false to send raw bytes + MIME.)
# HF_ASR_PROVIDER=hf-inference
# HF_ASR_MODEL=openai/whisper-large-v3
# HF_ASR_RUNTIME=hosted
# (hosted = try serverless inference first. local = always use Python Transformers script below.)
# HF_LOCAL_MODEL_CACHE=./data/.hf-cache/models
#
# Local ASR (Hub-only / Parakeet-style models without serverless routing):
# HF_ASR_LOCAL_PYTHON=/path/to/python3
# HF_ASR_LOCAL_SCRIPT=./server/scripts/hf_local_asr.py
# HF_ASR_TRUST_REMOTE_CODE=1
# pip install "transformers[torch]" torch torchaudio soundfile accelerate
#
# HF_EMBED_MODEL=intfloat/multilingual-e5-small
# LIBRARY_ROOT=./data/library
# API_PORT=8787
